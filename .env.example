# ─────────────────────────────────────────────────────────────────────────────
#  BabyDoll Token ($BDOLL) — Environment Variables
#  Target network: Polygon Mainnet (Chain ID 137)
#
#  Copy this file to .env and fill in real values.
#  NEVER commit .env to version control — it is in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Deployer wallet ──────────────────────────────────────────────────────────
# Private key of your DEDICATED deployment wallet (not your main wallet).
# Needs MATIC on Polygon Mainnet to pay gas (~$0.05–$0.20 for deployment).
# With or without the 0x prefix — both work.
PRIVATE_KEY=your_private_key_here

# ── Polygon RPC endpoints ────────────────────────────────────────────────────
# Mainnet — choose ONE provider:
#   Public (free, rate-limited): https://polygon-rpc.com
#   Alchemy (recommended):       https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
#   Infura:                      https://polygon-mainnet.infura.io/v3/YOUR_KEY
#   QuickNode:                   https://your-endpoint.quiknode.pro/YOUR_KEY
POLYGON_MAINNET_RPC=https://polygon-rpc.com

# Amoy Testnet (replaces deprecated Mumbai)
#   Public: https://rpc-amoy.polygon.technology
#   Alchemy: https://polygon-amoy.g.alchemy.com/v2/YOUR_KEY
POLYGON_AMOY_RPC=https://rpc-amoy.polygon.technology

# ── PolygonScan API key ───────────────────────────────────────────────────────
# Required for contract source-code verification on PolygonScan.
# Get a free key at: https://polygonscan.com/myapikey
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here

# ── Initial token owner (optional) ───────────────────────────────────────────
# Address that receives the 1B initial supply and the owner role.
# Defaults to the deployer address if not set.
# STRONGLY recommended: set this to a Gnosis Safe multisig on mainnet.
# INITIAL_OWNER=0xYourMultisigOrTreasuryAddressHere

# ── Gas reporting (optional) ─────────────────────────────────────────────────
# Set to "true" to print gas cost estimates (in MATIC + USD) during tests.
# REPORT_GAS=true

# CoinMarketCap API key for live MATIC/USD price in gas reports.
# Get a free key at: https://pro.coinmarketcap.com/signup
# COINMARKETCAP_API_KEY=your_coinmarketcap_api_key_here
