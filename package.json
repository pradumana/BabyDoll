{
  "name": "babydoll-token",
  "version": "1.0.0",
  "description": "BabyDoll (BDOLL) ERC-20 token — Polygon Mainnet deployment",
  "scripts": {
    "compile":          "npx hardhat compile",
    "test":             "npx hardhat test",
    "test:gas":         "cross-env REPORT_GAS=true npx hardhat test",

    "deploy:testnet":   "npx hardhat run scripts/deploy.js --network amoy",
    "deploy:mainnet":   "npx hardhat run scripts/deploy.js --network polygon",

    "verify:testnet":   "npx hardhat verify --network amoy",
    "verify:mainnet":   "npx hardhat verify --network polygon",

    "estimate:gas":     "npx hardhat run scripts/estimate-gas.js --network polygon",

    "node":             "npx hardhat node"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "cross-env": "^7.0.3",
    "hardhat": "^2.22.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0",
    "dotenv": "^16.4.5"
  }
}
